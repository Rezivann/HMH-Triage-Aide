NODE_ENV=development
PORT=4000

DATABASE_URL=mongodb://localhost:27017/llmtriage

# app.js - frontend dev server origin (Vite default)
CORS_ORIGIN=http://localhost:5173

# kioskAuth.js
KIOSK_API_KEY_SECRET=

# nurseAuth.js - Cisco Duo SSO
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=
DUO_API_HOST=
NURSE_SESSION_SECRET=dev-insecure-nurse-secret

# trackAuth.js
TRACK_TOKEN_SECRET=dev-insecure-track-secret

# photoAuth.js - short-lived, session-scoped token embedded in the kiosk's QR
# code so a patient's phone can submit a photo without ever holding the
# device's own long-lived KIOSK_API_KEY_SECRET
PHOTO_TOKEN_SECRET=dev-insecure-photo-secret

# LlmService - Anthropic Messages API
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5
LLM_API_VERSION=2023-06-01

# CvServiceClient -> ml-service
CV_SERVICE_URL=http://localhost:8000

# ContactCenterService - Webex Contact Center
WEBEX_CC_CLIENT_ID=
WEBEX_CC_CLIENT_SECRET=
WEBEX_CC_ORG_ID=

# queueSort.js - decay rates and caps are per-category now, nurse-editable
# from the dashboard, so they live in fakeAcuityPolicyStore.js, not here
