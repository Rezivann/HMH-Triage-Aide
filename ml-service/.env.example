ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# vision_llm_client.py - Stage 3 findings/synthesis, the only step that spends LLM tokens
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# wound_segmentation.py - MedSAM (bowang-lab), hosted on a private Hugging
# Face Inference Endpoint - see ml-service/medsam-hf-endpoint/README.md.
# Wound-only - nail segmentation/scale-factor estimation was removed.
MEDSAM_ENDPOINT_URL=
MEDSAM_API_KEY=

# capture_quality.py - Laplacian-variance blur threshold, calibrate against
# real kiosk camera photos rather than trusting this default
BLUR_THRESHOLD=10

# mirrors back-end's ReviewRoutingService.LOW_CONFIDENCE_THRESHOLD - keep in sync
LOW_CONFIDENCE_THRESHOLD=0.6

LOG_LEVEL=info
