ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# vision_llm_client.py - Stage 3 findings/synthesis, the only step that spends LLM tokens
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# nail_segmentation.py + wound_segmentation.py - MedSAM (bowang-lab), hosted on
# a private Hugging Face Inference Endpoint - see ml-service/medsam-hf-endpoint/README.md.
# Used for both nail and wound segmentation.
MEDSAM_ENDPOINT_URL=
MEDSAM_API_KEY=

# nail_segmentation.py - reference object for the mm-per-pixel scale factor
# (always the index fingernail, pressed flat against the skin next to the wound)
NAIL_AVG_WIDTH_MM=12.0
NAIL_WIDTH_MARGIN_MM=2.0

# measurement.py - fallback used when the patient couldn't place their finger next
# to the wound (no nail reference available), deliberately low-confidence/high-margin
FALLBACK_SCALE_MM_PER_PIXEL=0.3
FALLBACK_SCALE_CONFIDENCE=0.3
FALLBACK_AREA_MARGIN_PERCENT=50.0

# capture_quality.py - Laplacian-variance blur threshold, calibrate against
# real kiosk camera photos rather than trusting this default
BLUR_THRESHOLD=125

# mirrors back-end's ReviewRoutingService.LOW_CONFIDENCE_THRESHOLD - keep in sync
LOW_CONFIDENCE_THRESHOLD=0.6

LOG_LEVEL=info
