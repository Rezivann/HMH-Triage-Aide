PUBLIC_API_BASE_URL=http://localhost:4000

# Dev-only stand-in for the kiosk API key a real device gets baked in at
# Control Hub provisioning. Must be a JWT signed with the same
# KIOSK_API_KEY_SECRET the backend has in back-end/.env - mint one with:
#
#   node -e "console.log(require('jsonwebtoken').sign({ kioskId: 'kiosk-1', locationId: 'loc-1' }, 'YOUR_KIOSK_API_KEY_SECRET'))"
#
# run from back-end/ so it can resolve the jsonwebtoken package.
PUBLIC_KIOSK_API_KEY=
